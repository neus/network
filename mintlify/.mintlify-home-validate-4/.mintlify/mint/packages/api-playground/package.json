{
  "name": "@mintlify/api-playground",
  "version": "0.0.33",
  "description": "Mintlify API Playground",
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "Mintlify, Inc.",
  "license": "Elastic-2.0",
  "keywords": [
    "mintlify",
    "api-playground"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/mintlify/mint",
    "directory": "packages/api-playground"
  },
  "scripts": {
    "prepare": "npm run build",
    "build": "tsc --project tsconfig.build.json",
    "clean:build": "rimraf dist",
    "clean:all": "rimraf node_modules .eslintcache && yarn clean:build",
    "watch": "tsc --watch",
    "format": "prettier \"./src/**/*.ts\" \"./test/**/*.ts\" \"./vitest.config.ts\" --write",
    "format:check": "prettier \"./src/**/*.ts\" \"./test/**/*.ts\" \"./vitest.config.ts\" --check",
    "lint": "eslint src test --cache",
    "test": "vitest run",
    "type": "tsc --noEmit"
  },
  "dependencies": {
    "@mintlify/common": "1.0.788",
    "@mintlify/httpsnippet": "1.0.6",
    "@mintlify/models": "0.0.283",
    "@mintlify/validation": "0.1.626",
    "@sindresorhus/slugify": "2.2.0",
    "html-react-parser": "3.0.12",
    "lodash": "4.17.21",
    "openapi-types": "12.1.3",
    "uuid": "11.1.0",
    "zustand": "5.0.6"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "devDependencies": {
    "@mintlify/eslint-config-typescript": "1.0.13",
    "@mintlify/prettier-config": "1.0.4",
    "@mintlify/ts-config": "2.0.2",
    "@tsconfig/recommended": "1.0.2",
    "@types/har-format": "1.2.16",
    "@types/react": "^19.2.1",
    "@types/react-dom": "^19.2.1",
    "@typescript-eslint/parser": "6.9.1",
    "eslint": "8.36.0",
    "eslint-plugin-react-hooks": "4.6.2",
    "prettier": "3.3.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rimraf": "5.0.1",
    "typescript": "5.5.3",
    "vitest": "2.0.4"
  }
}
