{
  "$schema": "https://code.claude.com/schemas/plugin.json",
  "name": "neus-core",
  "version": "1.0.0",
  "description": "NEUS Core - Verification Network integration with Zeus agent. Create proofs, verify identities, delegate agent authority.",
  "author": {
    "name": "NEUS Network",
    "email": "info@neus.network",
    "url": "https://neus.network"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/neus/network.git",
    "directory": "plugins/neus-core"
  },
  "license": "Apache-2.0",
  "keywords": [
    "neus",
    "verification",
    "proofs",
    "agents",
    "identity",
    "web3",
    "blockchain"
  ],
  "agents": [
    {
      "name": "zeus",
      "path": "agents/zeus.md",
      "default": true
    }
  ],
  "skills": [
    {
      "name": "verify",
      "path": "skills/verify/SKILL.md"
    },
    {
      "name": "create-agent",
      "path": "skills/create-agent/SKILL.md"
    },
    {
      "name": "audit",
      "path": "skills/audit/SKILL.md"
    }
  ],
  "mcpServers": {
    "neus": {
      "type": "streamableHttp",
      "url": "https://mcp.neus.network/mcp",
      "description": "NEUS MCP - verification, proofs, and agent management"
    }
  },
  "compatibility": {
    "claudeCode": ">=1.0.0",
    "cursor": ">=0.45.0"
  },
  "links": {
    "documentation": "https://docs.neus.network",
    "website": "https://neus.network"
  }
}
