# Default `npm run dev` uses a local mock API and same-origin mock hosted checkout (no production calls).
# Copy to .env.local and override when pointing at the real network.

VITE_NEUS_APP_ID=local-demo
VITE_NEUS_API_URL=http://127.0.0.1:8787
# Optional: use live Hosted Verify (opens neus.network or your URL)
# VITE_NEUS_HOSTED_CHECKOUT_URL=https://neus.network/verify
