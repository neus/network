{
  "$schema": "https://mintlify.com/docs.json",
  "name": "NEUS",
  "theme": "mint",
  "logo": {
    "light": "/images/neus-logo.svg",
    "dark": "/images/neus-logo.svg",
    "href": "https://neus.network"
  },
  "favicon": "/images/neus-logo.svg",
  "colors": {
    "primary": "#98C0EF",
    "light": "#98C0EF",
    "dark": "#3D72C9"
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "background": {
    "decoration": "gradient",
    "color": {
      "dark": "#101113"
    }
  },
  "styling": {
    "custom": "styles.css",
    "eyebrows": "breadcrumbs"
  },
  "fonts": {
    "body": {
      "family": "Inter",
      "weight": 400
    },
    "heading": {
      "family": "Inter",
      "weight": 600
    }
  },
  "seo": {
    "metatags": {
      "canonical": "https://docs.neus.network",
      "theme-color": "#101113",
      "color-scheme": "dark"
    }
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/neus/network"
      },
      {
        "label": "Support",
        "href": "https://github.com/neus/network/discussions"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open Hub",
      "href": "https://neus.network/hub"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Overview",
        "groups": [
          {
            "group": "Get Started",
