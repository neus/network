{
  "$schema": "https://mintlify.com/docs.json",
  "name": "NEUS",
  "theme": "mint",
  "logo": {
    "light": "/images/neus-logo.svg",
    "dark": "/images/neus-logo.svg",
    "href": "https://neus.network"
  },
  "favicon": "/images/neus-logo.svg",
  "colors": {
    "primary": "#98C0EF",
    "light": "#98C0EF",
    "dark": "#98C0EF"
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "background": {
    "decoration": "gradient",
    "color": {
      "dark": "#101113"
    }
  },
  "styling": {
    "custom": "styles.css",
    "eyebrows": "breadcrumbs"
  },
  "fonts": {
    "body": {
      "family": "Inter",
      "weight": 400
    },
    "heading": {
      "family": "Inter",
      "weight": 600
    }
  },
  "seo": {
    "metatags": {
      "theme-color": "#101113",
      "color-scheme": "dark",
      "description": "NEUS Docs — verify once, trust everywhere. Proof receipts for login, access, and agents.",
      "og:title": "NEUS Documentation",
      "og:description": "Proof receipts for login, access, and agents.",
      "og:image": "https://docs.neus.network/images/og-default.png",
      "og:image:width": "1200",
      "og:image:height": "630",
      "og:type": "website",
      "og:site_name": "NEUS Docs",
      "twitter:card": "summary_large_image",
      "twitter:title": "NEUS Documentation",
      "twitter:description": "Proof receipts for login, access, and agents.",
      "twitter:image": "https://docs.neus.network/images/og-default.png"
    }
  },
