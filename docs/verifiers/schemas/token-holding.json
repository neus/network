{
  "$id": "https://neus.network/schemas/token-holding.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Token holding verification (EVM or Solana)",
  "oneOf": [
    {
      "required": [
        "chainId"
      ]
    },
    {
      "required": [
        "chain"
      ]
    }
  ],
  "properties": {
    "blockNumber": {
      "minimum": 0,
      "type": "integer"
    },
    "chain": {
      "description": "CAIP-2 for Solana (e.g. solana:mainnet)",
      "type": "string"
    },
    "chainId": {
      "minimum": 1,
      "type": "integer"
    },
    "contractAddress": {
      "format": "universal-address",
      "type": "string"
    },
    "minBalance": {
      "minLength": 1,
      "type": "string"
    },
    "ownerAddress": {
      "format": "universal-address",
      "type": "string"
    }
  },
  "required": [
    "contractAddress",
    "minBalance"
  ],
  "title": "token-holding",
  "type": "object"
}
