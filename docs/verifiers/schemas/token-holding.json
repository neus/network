{
  "$id": "https://neus.network/schemas/token-holding.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Token holding verification (EVM-only)",
  "properties": {
    "blockNumber": {
      "minimum": 0,
      "type": "integer"
    },
    "chainId": {
      "minimum": 1,
      "type": "integer"
    },
    "contractAddress": {
      "format": "evm-address",
      "type": "string"
    },
    "minBalance": {
      "minLength": 1,
      "type": "string"
    },
    "ownerAddress": {
      "format": "evm-address",
      "type": "string"
    }
  },
  "required": [
    "contractAddress",
    "minBalance",
    "chainId"
  ],
  "title": "token-holding",
  "type": "object"
}
