{
  "$id": "https://neus.network/schemas/agent-delegation.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Delegates authority to an agent, ERC-8004 compatible",
  "properties": {
    "agentId": {
      "maxLength": 128,
      "type": "string"
    },
    "agentWallet": {
      "format": "evm-address",
      "type": "string"
    },
    "allowedPaymentTypes": {
      "items": {
        "maxLength": 32,
        "type": "string"
      },
      "type": "array"
    },
    "controllerWallet": {
      "format": "evm-address",
      "type": "string"
    },
    "expiresAt": {
      "minimum": 0,
      "type": "integer"
    },
    "maxSpend": {
      "type": "string"
    },
    "permissions": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "receiptDisclosure": {
      "enum": [
        "none",
        "summary",
        "full"
      ],
      "type": "string"
    },
    "scope": {
      "maxLength": 128,
      "type": "string"
    }
  },
  "required": [
    "controllerWallet",
    "agentWallet"
  ],
  "title": "agent-delegation",
  "type": "object"
}
