{
  "$id": "https://neus.network/schemas/wallet-risk.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Wallet risk verification via multi-provider support (sybil/fraud resistance)",
  "properties": {
    "chainId": {
      "description": "Chain ID for context",
      "type": "integer"
    },
    "includeDetails": {
      "description": "Include detailed risk breakdown",
      "type": "boolean"
    },
    "provider": {
      "description": "Risk assessment provider (default: webacy)",
      "enum": [
        "webacy"
      ],
      "type": "string"
    },
    "walletAddress": {
      "description": "Wallet address to assess (optional; defaults to signer walletAddress)",
      "pattern": "^0x[a-fA-F0-9]{40}$",
      "type": "string"
    }
  },
  "required": [],
  "title": "wallet-risk",
  "type": "object"
}