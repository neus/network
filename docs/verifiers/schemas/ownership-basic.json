{
  "$id": "https://neus.network/schemas/ownership-basic.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Content ownership verification with origin lock and optional provenance",
  "properties": {
    "content": {
      "description": "Content being claimed (max 50KB inline; use contentHash + IPFS for larger)",
      "maxLength": 50000,
      "type": "string"
    },
    "contentHash": {
      "description": "Pre-computed SHA-256 or keccak256 hash (optional if content provided)",
      "pattern": "^0x[a-fA-F0-9]{64}$",
      "type": "string"
    },
    "contentType": {
      "description": "MIME type hint for the content/reference (e.g., image/png, audio/mpeg, application/pdf)",
      "maxLength": 100,
      "type": "string"
    },
    "owner": {
      "description": "Wallet address of the owner (must match request walletAddress)",
      "pattern": "^0x[a-fA-F0-9]{40}$",
      "type": "string"
    },
    "provenance": {
      "description": "Optional provenance metadata for content origin",
      "properties": {
        "aiContext": {
          "description": "AI generation context (when declaredKind is ai or mixed)",
          "properties": {
            "generatorType": {
              "description": "Type of AI generator",
              "enum": [
                "local",
                "saas",
                "agent"
              ],
              "type": "string"
            },
            "model": {
              "description": "Model identifier (opaque string)",
              "maxLength": 128,
              "type": "string"
            },
            "provider": {
              "description": "AI provider (e.g., openai, anthropic, other)",
              "maxLength": 64,
              "type": "string"
            },
            "runId": {
              "description": "Model run identifier",
              "maxLength": 128,
              "type": "string"
            }
          },
          "type": "object"
        },
        "declaredKind": {
          "description": "Content creation type (advisory, not verified)",
          "enum": [
            "human",
            "ai",
            "mixed",
            "unknown"
          ],
          "type": "string"
        }
      },
      "type": "object"
    },
    "reference": {
      "properties": {
        "description": {
          "description": "Optional description",
          "maxLength": 500,
          "type": "string"
        },
        "id": {
          "description": "Reference identifier (CID, URL, tx hash, chainId:address:tokenId, etc.)",
          "maxLength": 2048,
          "type": "string"
        },
        "mime": {
          "description": "MIME type for file references",
          "maxLength": 100,
          "type": "string"
        },
        "name": {
          "description": "Original filename for file references",
          "maxLength": 255,
          "type": "string"
        },
        "size": {
          "description": "File size in bytes",
          "type": "integer"
        },
        "title": {
          "description": "Optional display title",
          "maxLength": 200,
          "type": "string"
        },
        "type": {
          "description": "Reference type for traceability",
          "enum": [
            "ipfs",
            "ipfs-hash",
            "url",
            "license-nft",
            "contract",
            "qhash",
            "ethereum-tx",
            "on-chain-tx",
            "tx",
            "file",
            "doc",
            "media",
            "username-claim",
            "other"
          ],
          "type": "string"
        }
      },
      "required": [
        "type"
      ],
      "type": "object"
    }
  },
  "required": [
    "owner"
  ],
  "title": "ownership-basic",
  "type": "object"
}