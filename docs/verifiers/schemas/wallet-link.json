{
  "$id": "https://neus.network/schemas/wallet-link.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Links and verifies control of a secondary wallet via cryptographic signature",
  "properties": {
    "chainId": {
      "description": "Chain ID for link context",
      "type": "integer"
    },
    "label": {
      "description": "Human-readable label for this wallet",
      "maxLength": 64,
      "type": "string"
    },
    "primaryWalletAddress": {
      "description": "Primary wallet (owner)",
      "pattern": "^0x[a-fA-F0-9]{40}$",
      "type": "string"
    },
    "relationshipType": {
      "description": "Relationship type for identity graph categorization",
      "enum": [
        "primary",
        "personal",
        "org",
        "affiliate",
        "agent",
        "linked"
      ],
      "type": "string"
    },
    "secondaryWalletAddress": {
      "description": "Secondary wallet (must sign)",
      "pattern": "^0x[a-fA-F0-9]{40}$",
      "type": "string"
    },
    "signature": {
      "description": "EIP-191 signature from secondary wallet over canonical message",
      "type": "string"
    },
    "signedTimestamp": {
      "description": "Unix timestamp (ms) when signed",
      "type": "integer"
    }
  },
  "required": [
    "primaryWalletAddress",
    "secondaryWalletAddress",
    "signature",
    "chainId",
    "signedTimestamp"
  ],
  "title": "wallet-link",
  "type": "object"
}