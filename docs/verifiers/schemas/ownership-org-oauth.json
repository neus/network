{
  "$id": "https://neus.network/schemas/ownership-org-oauth.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Organizational OAuth verification",
  "properties": {
    "expectedOrgDomain": {
      "format": "hostname",
      "type": "string"
    },
    "internalSocialToken": {
      "type": "string"
    },
    "provider": {
      "enum": [
        "google",
        "microsoft"
      ],
      "type": "string"
    },
    "walletAddress": {
      "format": "universal-address",
      "type": "string"
    }
  },
  "required": [
    "provider",
    "internalSocialToken"
  ],
  "title": "ownership-org-oauth",
  "type": "object"
}
