{
  "$id": "https://neus.network/schemas/agent-identity.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Portable agent identity, ERC-8004 compatible",
  "properties": {
    "agentId": {
      "maxLength": 128,
      "type": "string"
    },
    "agentLabel": {
      "maxLength": 128,
      "type": "string"
    },
    "agentType": {
      "enum": [
        "ai",
        "bot",
        "service",
        "automation",
        "agent"
      ],
      "type": "string"
    },
    "agentWallet": {
      "format": "evm-address",
      "type": "string"
    },
    "capabilities": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "description": {
      "maxLength": 500,
      "type": "string"
    }
  },
  "required": [
    "agentId",
    "agentWallet"
  ],
  "title": "agent-identity",
  "type": "object"
}
