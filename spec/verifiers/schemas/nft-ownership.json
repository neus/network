{
  "$id": "https://neus.network/schemas/nft-ownership.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "NFT ownership verification (EVM-only)",
  "properties": {
    "blockNumber": {
      "minimum": 0,
      "type": "integer"
    },
    "chainId": {
      "minimum": 1,
      "type": "integer"
    },
    "contractAddress": {
      "format": "evm-address",
      "type": "string"
    },
    "ownerAddress": {
      "format": "evm-address",
      "type": "string"
    },
    "tokenId": {
      "minLength": 1,
      "type": "string"
    },
    "tokenType": {
      "default": "erc721",
      "enum": [
        "erc721",
        "erc1155"
      ],
      "type": "string"
    }
  },
  "required": [
    "contractAddress",
    "tokenId",
    "chainId"
  ],
  "title": "nft-ownership",
  "type": "object"
}
