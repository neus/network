{
  "$id": "https://neus.network/schemas/nft-ownership.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "NFT ownership verification (EVM or Solana)",
  "type": "object",
  "required": ["contractAddress", "tokenId"],
  "oneOf": [
    { "required": ["chainId"] },
    { "required": ["chain"] }
  ],
  "properties": {
    "contractAddress": {
      "type": "string",
      "description": "EVM contract or Solana mint (base58)"
    },
    "ownerAddress": {
      "type": "string",
      "description": "EVM (0x...) or Solana (base58). Optional; defaults to signer."
    },
    "tokenId": {
      "minLength": 1,
      "type": "string"
    },
    "tokenType": {
      "default": "erc721",
      "enum": ["erc721", "erc1155"],
      "type": "string"
    },
    "chainId": {
      "minimum": 1,
      "type": "integer",
      "description": "EVM chain ID"
    },
    "chain": {
      "type": "string",
      "description": "CAIP-2 for Solana (e.g. solana:mainnet)"
    },
    "blockNumber": {
      "minimum": 0,
      "type": "integer"
    }
  },
  "title": "nft-ownership"
}
