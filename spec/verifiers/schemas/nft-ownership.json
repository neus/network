{
  "$id": "https://neus.network/schemas/nft-ownership.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "nft-ownership",
  "description": "NFT ownership verification (EVM or Solana)",
  "type": "object",
  "required": [
    "contractAddress",
    "tokenId"
  ],
  "oneOf": [
    {
      "required": [
        "chainId"
      ]
    },
    {
      "required": [
        "chain"
      ]
    }
  ],
  "properties": {
    "ownerAddress": {
      "type": "string",
      "format": "universal-address"
    },
    "contractAddress": {
      "type": "string",
      "format": "universal-address"
    },
    "tokenId": {
      "type": "string",
      "minLength": 1
    },
    "tokenType": {
      "type": "string",
      "enum": [
        "erc721",
        "erc1155"
      ],
      "default": "erc721"
    },
    "chainId": {
      "type": "integer",
      "minimum": 1
    },
    "chain": {
      "type": "string",
      "description": "CAIP-2 for Solana (e.g. solana:mainnet)"
    },
    "blockNumber": {
      "type": "integer",
      "minimum": 0
    }
  }
}
