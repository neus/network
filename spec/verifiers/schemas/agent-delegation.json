{
  "$id": "https://neus.network/schemas/agent-delegation.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "agent-delegation",
  "description": "Delegates scoped authority from a delegating account to an agent, ERC-8004 compatible",
  "type": "object",
  "anyOf": [
    {
      "required": [
        "controllerAccountId",
        "agentAccountId"
      ]
    },
    {
      "required": [
        "controllerWallet",
        "controllerChainRef",
        "agentWallet",
        "agentChainRef"
      ]
    }
  ],
  "properties": {
    "controllerAccountId": {
      "type": "string",
      "format": "caip10-account",
      "description": "Preferred canonical controller identity (CAIP-10)."
    },
    "controllerChainRef": {
      "type": "string",
      "format": "caip2-chain",
      "description": "Required when using legacy controllerWallet without controllerAccountId."
    },
    "controllerWallet": {
      "type": "string",
      "format": "universal-address"
    },
    "agentAccountId": {
      "type": "string",
      "format": "caip10-account",
      "description": "Preferred canonical agent identity (CAIP-10)."
    },
    "agentChainRef": {
      "type": "string",
      "format": "caip2-chain",
      "description": "Required when using legacy agentWallet without agentAccountId."
    },
    "agentWallet": {
      "type": "string",
      "format": "universal-address"
    },
    "agentId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "scope": {
      "type": "string",
      "maxLength": 128
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 64
      },
      "maxItems": 32
    },
    "maxSpend": {
      "type": "string",
      "pattern": "^[0-9]{1,78}$",
      "description": "Spend cap as a whole-number string in token base units (no decimal point). USDC (common x402): six decimal places; native ETH-style assets: eighteen."
    },
    "allowedPaymentTypes": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 32
      },
      "maxItems": 8
    },
    "receiptDisclosure": {
      "type": "string",
      "enum": [
        "none",
        "summary",
        "full"
      ]
    },
    "expiresAt": {
      "type": "integer",
      "minimum": 0
    },
    "instructions": {
      "type": "string",
      "maxLength": 4000
    },
    "skills": {
      "type": "array",
      "description": "Agent skills as structured objects",
      "maxItems": 48,
      "items": {
        "type": "object",
        "required": [
          "id"
        ],
        "properties": {
          "id": {
            "type": "string",
            "maxLength": 64
          },
          "label": {
            "type": "string",
            "maxLength": 64
          },
          "version": {
            "type": "string",
            "maxLength": 32
          },
          "provider": {
            "type": "string",
            "maxLength": 64
          },
          "kind": {
            "type": "string",
            "enum": [
              "native",
              "integration",
              "plugin",
              "mcp",
              "toolkit"
            ]
          },
          "configId": {
            "type": "string",
            "maxLength": 128
          },
          "enabled": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
