{
  "$id": "https://neus.network/schemas/agent-delegation.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Delegates authority to an agent, ERC-8004 compatible",
  "definitions": {
    "AgentSkillRef": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "maxLength": 64, "description": "Canonical skill ID from catalog" },
        "label": { "type": "string", "maxLength": 64, "description": "Display label snapshot" },
        "version": { "type": "string", "maxLength": 32, "description": "Installed version" },
        "provider": { "type": "string", "maxLength": 64, "description": "Provider snapshot" },
        "kind": { "type": "string", "enum": ["native", "integration", "plugin", "mcp", "toolkit"], "description": "Skill kind" },
        "configId": { "type": "string", "maxLength": 128, "description": "Linked config/connection ID" },
        "enabled": { "type": "boolean", "description": "Whether skill is active", "default": true }
      },
      "required": ["id"]
    }
  },
  "properties": {
    "agentAccountId": {
      "format": "caip10-account",
      "type": "string",
      "description": "CAIP-10 account ID for the agent. Alternative to agentWallet + agentChainRef."
    },
    "agentChainRef": {
      "format": "caip2-chain",
      "type": "string",
      "description": "CAIP-2 chain reference when using agentWallet"
    },
    "agentId": {
      "maxLength": 128,
      "minLength": 1,
      "type": "string"
    },
    "agentWallet": {
      "format": "universal-address",
      "type": "string",
      "description": "EVM (0x + 40 hex chars) or Solana (Base58, 32-44 chars) address"
    },
    "allowedPaymentTypes": {
      "items": { "maxLength": 32, "type": "string" },
      "maxItems": 8,
      "type": "array",
      "description": "Payment protocols (e.g. [\"x402\"]). Defaults to [\"x402\"] when scope is payments:x402."
    },
    "controllerAccountId": {
      "format": "caip10-account",
      "type": "string",
      "description": "CAIP-10 account ID for the controller. Must match signer."
    },
    "controllerChainRef": {
      "format": "caip2-chain",
      "type": "string",
      "description": "CAIP-2 chain reference when using controllerWallet"
    },
    "controllerWallet": {
      "format": "universal-address",
      "type": "string",
      "description": "EVM (0x + 40 hex chars) or Solana (Base58, 32-44 chars) address. Must match signer."
    },
    "expiresAt": {
      "minimum": 0,
      "type": "integer",
      "description": "Expiration timestamp in Unix milliseconds."
    },
    "instructions": {
      "maxLength": 4000,
      "type": "string",
      "description": "Instructions for the delegated agent (max 4000 chars)"
    },
    "maxSpend": {
      "type": "string",
      "pattern": "^[0-9]{1,78}$",
      "description": "Maximum spend in wei (decimal string)"
    },
    "permissions": {
      "items": { "maxLength": 64, "type": "string" },
      "maxItems": 32,
      "type": "array"
    },
    "receiptDisclosure": {
      "enum": ["none", "summary", "full"],
      "type": "string",
      "description": "How much of receipt payload may be disclosed. Defaults to \"summary\" for x402."
    },
    "scope": {
      "maxLength": 128,
      "type": "string",
      "description": "Scope of delegation (e.g. \"payments:x402\", \"posting\", \"global\")"
    },
    "skills": {
      "type": "array",
      "items": { "$ref": "#/definitions/AgentSkillRef" },
      "maxItems": 48,
      "description": "Structured skill references granted to the agent"
    }
  },
  "anyOf": [
    { "required": ["controllerAccountId", "agentAccountId"] },
    { "required": ["controllerWallet", "agentWallet"] }
  ],
  "title": "agent-delegation",
  "type": "object"
}