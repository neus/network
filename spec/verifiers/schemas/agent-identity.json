{
  "$id": "https://neus.network/schemas/agent-identity.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Portable agent identity — wallet-anchored, chain-agnostic, protocol-agnostic",
  "definitions": {
    "AgentSkillRef": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "maxLength": 64,
          "description": "Canonical skill ID from catalog"
        },
        "label": {
          "type": "string",
          "maxLength": 64,
          "description": "Display label snapshot"
        },
        "version": {
          "type": "string",
          "maxLength": 32,
          "description": "Installed version"
        },
        "provider": {
          "type": "string",
          "maxLength": 64,
          "description": "Provider snapshot"
        },
        "kind": {
          "type": "string",
          "enum": ["native", "integration", "plugin", "mcp", "toolkit"],
          "description": "Skill kind"
        },
        "configId": {
          "type": "string",
          "maxLength": 128,
          "description": "Linked config/connection ID"
        },
        "enabled": {
          "type": "boolean",
          "description": "Whether skill is active",
          "default": true
        }
      },
      "required": ["id"]
    },
    "AgentCapabilities": {
      "type": "object",
      "properties": {
        "wallet": {
          "type": "boolean",
          "description": "Can use wallet for signing/spending"
        },
        "signing": { "type": "boolean", "description": "Can sign messages" },
        "spending": { "type": "boolean", "description": "Can spend funds" },
        "publishing": {
          "type": "boolean",
          "description": "Can publish content"
        },
        "search": { "type": "boolean", "description": "Can use web search" },
        "browser": {
          "type": "boolean",
          "description": "Can use browser automation"
        },
        "mcp": { "type": "boolean", "description": "Can call MCP tools" },
        "webhooks": {
          "type": "boolean",
          "description": "Can receive webhooks"
        },
        "receipts": { "type": "boolean", "description": "Can post receipts" },
        "proofs": {
          "type": "boolean",
          "description": "Can create/verify proofs"
        },
        "delegation": {
          "type": "boolean",
          "description": "Can be delegated to"
        }
      }
    }
  },
  "properties": {
    "agentId": {
      "maxLength": 128,
      "minLength": 1,
      "type": "string"
    },
    "agentAccountId": {
      "format": "caip10-account",
      "type": "string",
      "description": "CAIP-10 account ID (e.g. eip155:8453:0x...). Alternative to agentWallet + agentChainRef."
    },
    "agentChainRef": {
      "format": "caip2-chain",
      "type": "string",
      "description": "CAIP-2 chain reference when using agentWallet (e.g. eip155:8453)"
    },
    "agentLabel": {
      "maxLength": 128,
      "type": "string"
    },
    "agentType": {
      "enum": ["ai", "bot", "service", "automation", "agent"],
      "type": "string"
    },
    "agentWallet": {
      "format": "universal-address",
      "type": "string",
      "description": "EVM (0x + 40 hex chars) or Solana (Base58, 32-44 chars) address"
    },
    "capabilities": {
      "$ref": "#/definitions/AgentCapabilities",
      "description": "Native platform capabilities as structured boolean flags"
    },
    "description": {
      "maxLength": 500,
      "type": "string"
    },
    "instructions": {
      "maxLength": 4000,
      "type": "string",
      "description": "System prompt or behavioral instructions for the agent (max 4000 chars)"
    },
    "skills": {
      "type": "array",
      "items": { "$ref": "#/definitions/AgentSkillRef" },
      "maxItems": 48,
      "description": "Structured skill references from the NEUS Skills Catalog"
    },
    "services": {
      "items": {
        "type": "object",
        "required": ["name", "endpoint"],
        "properties": {
          "name": { "maxLength": 64, "type": "string" },
          "endpoint": { "maxLength": 256, "type": "string", "format": "uri" },
          "version": { "maxLength": 32, "type": "string" }
        }
      },
      "maxItems": 16,
      "type": "array",
      "description": "Service endpoints exposed by this agent"
    }
  },
  "anyOf": [
    { "required": ["agentId", "agentAccountId"] },
    { "required": ["agentId", "agentWallet"] }
  ],
  "title": "agent-identity",
  "type": "object"
}
