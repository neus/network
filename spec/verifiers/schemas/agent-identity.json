{
  "$id": "https://neus.network/schemas/agent-identity.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Portable agent identity, ERC-8004 compatible",
  "properties": {
    "agentId": {
      "maxLength": 128,
      "minLength": 1,
      "type": "string"
    },
    "agentLabel": {
      "maxLength": 128,
      "type": "string"
    },
    "agentType": {
      "enum": [
        "ai",
        "bot",
        "service",
        "automation",
        "agent"
      ],
      "type": "string"
    },
    "agentWallet": {
      "format": "universal-address",
      "type": "string",
      "description": "EVM (0x + 40 hex chars) or Solana (Base58, 32-44 chars) address"
    },
    "capabilities": {
      "items": {
        "maxLength": 128,
        "type": "string"
      },
      "maxItems": 32,
      "type": "array"
    },
    "description": {
      "maxLength": 500,
      "type": "string"
    },
    "instructions": {
      "maxLength": 4000,
      "type": "string",
      "description": "System prompt or behavioral instructions for the agent (max 4000 chars)"
    },
    "skills": {
      "items": {
        "maxLength": 64,
        "type": "string"
      },
      "maxItems": 48,
      "type": "array",
      "description": "Declared skill identifiers (each max 64 chars, max 48 entries)"
    },
    "services": {
      "items": {
        "type": "object",
        "required": ["name", "endpoint"],
        "properties": {
          "name": {
            "maxLength": 64,
            "type": "string"
          },
          "endpoint": {
            "maxLength": 256,
            "type": "string",
            "format": "uri"
          },
          "version": {
            "maxLength": 32,
            "type": "string"
          }
        }
      },
      "maxItems": 16,
      "type": "array",
      "description": "Service endpoints exposed by this agent (each requires name and a valid URL endpoint)"
    }
  },
  "required": [
    "agentId",
    "agentWallet"
  ],
  "title": "agent-identity",
  "type": "object"
}
