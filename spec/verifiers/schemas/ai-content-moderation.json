{
  "$id": "https://neus.network/schemas/ai-content-moderation.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ai-content-moderation",
  "description": "Verifies content safety via AI",
  "type": "object",
  "required": [
    "content",
    "contentType"
  ],
  "properties": {
    "content": {
      "type": "string",
      "maxLength": 13653334
    },
    "contentType": {
      "type": "string",
      "enum": [
        "image/jpeg",
        "image/png",
        "image/webp",
        "image/gif",
        "text/plain",
        "text/markdown",
        "text/x-markdown",
        "application/json",
        "application/xml"
      ]
    },
    "provider": {
      "type": "string",
      "enum": [
        "google-vision",
        "google-perspective"
      ]
    }
  }
}
