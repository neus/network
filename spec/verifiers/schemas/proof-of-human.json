{
  "$id": "https://neus.network/schemas/proof-of-human.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "proof-of-human",
  "description": "Unique human verification for sybil resistance",
  "type": "object",
  "required": [
    "proofs",
    "queryResult"
  ],
  "properties": {
    "provider": {
      "type": "string",
      "enum": [
        "zkpassport"
      ]
    },
    "proofs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10
    },
    "queryResult": {
      "type": "object"
    },
    "scope": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_-]{1,64}$"
    }
  }
}
