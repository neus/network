{
  "$id": "https://neus.network/schemas/proof-of-human.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "proof-of-human",
  "description": "Select the human-verification provider to complete in hosted verify.",
  "type": "object",
  "required": [
    "provider"
  ],
  "properties": {
    "provider": {
      "type": "string",
      "enum": [
        "zkpassport"
      ]
    },
    "scope": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_-]{1,64}$"
    }
  }
}
