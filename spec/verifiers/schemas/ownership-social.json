{
  "$id": "https://neus.network/schemas/ownership-social.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ownership-social",
  "description": "Select the linked social provider to complete in hosted verify.",
  "type": "object",
  "required": [
    "provider"
  ],
  "properties": {
    "provider": {
      "type": "string",
      "enum": [
        "discord",
        "github",
        "facebook",
        "x",
        "farcaster",
        "linkedin",
        "telegram",
        "coinbase"
      ],
      "description": "OAuth provider to verify against."
    }
  }
}
