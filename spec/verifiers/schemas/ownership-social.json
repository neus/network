{
  "$id": "https://neus.network/schemas/ownership-social.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ownership-social",
  "description": "Social media account ownership via OAuth",
  "type": "object",
  "required": [
    "provider",
    "internalSocialToken"
  ],
  "properties": {
    "provider": {
      "type": "string",
      "enum": [
        "discord",
        "github",
        "facebook",
        "x",
        "farcaster",
        "linkedin",
        "telegram",
        "coinbase"
      ]
    },
    "internalSocialToken": {
      "type": "string"
    },
    "walletAddress": {
      "type": "string",
      "format": "universal-address"
    }
  }
}
