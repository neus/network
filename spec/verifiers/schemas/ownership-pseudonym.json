{
  "$id": "https://neus.network/schemas/ownership-pseudonym.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ownership-pseudonym",
  "description": "Pseudonymous identity - wallet ↔ handle binding",
  "type": "object",
  "required": [
    "pseudonymId"
  ],
  "properties": {
    "pseudonymId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{1,30}[a-z0-9]$",
      "minLength": 3,
      "maxLength": 32
    },
    "namespace": {
      "type": "string",
      "pattern": "^[a-z0-9]([a-z0-9._-]*[a-z0-9])?$",
      "minLength": 1,
      "maxLength": 64,
      "default": "neus"
    },
    "displayName": {
      "type": "string",
      "maxLength": 64
    },
    "metadata": {
      "type": "object"
    }
  }
}
