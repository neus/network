{
  "$id": "https://neus.network/schemas/wallet-risk.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "wallet-risk",
  "description": "Wallet risk assessment",
  "type": "object",
  "required": [
    "walletAddress"
  ],
  "properties": {
    "provider": {
      "type": "string",
      "enum": [
        "webacy"
      ],
      "default": "webacy"
    },
    "walletAddress": {
      "anyOf": [
        {
          "type": "string",
          "format": "evm-address"
        },
        {
          "type": "string",
          "format": "solana-address"
        }
      ]
    },
    "chain": {
      "type": "string",
      "enum": [
        "eth",
        "base",
        "bsc",
        "pol",
        "opt",
        "arb",
        "sol",
        "ton",
        "sei",
        "sui",
        "btc",
        "stellar"
      ]
    },
    "chainId": {
      "type": "integer",
      "minimum": 1
    }
  }
}
