{
  "$id": "https://neus.network/schemas/ownership-org-oauth.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ownership-org-oauth",
  "description": "Select the organization provider to complete in hosted verify.",
  "type": "object",
  "required": [
    "provider"
  ],
  "properties": {
    "provider": {
      "type": "string",
      "enum": [
        "google",
        "microsoft"
      ]
    },
    "expectedOrgDomain": {
      "type": "string",
      "format": "hostname"
    }
  }
}
