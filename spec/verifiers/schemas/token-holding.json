{
  "$id": "https://neus.network/schemas/token-holding.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Token holding verification (EVM or Solana)",
  "type": "object",
  "required": ["contractAddress", "minBalance"],
  "oneOf": [
    { "required": ["chainId"] },
    { "required": ["chain"] }
  ],
  "properties": {
    "contractAddress": {
      "type": "string",
      "description": "EVM token contract or Solana SPL mint (base58)"
    },
    "ownerAddress": {
      "type": "string",
      "description": "EVM (0x...) or Solana (base58). Optional; defaults to signer."
    },
    "minBalance": {
      "minLength": 1,
      "type": "string"
    },
    "chainId": {
      "minimum": 1,
      "type": "integer",
      "description": "EVM chain ID"
    },
    "chain": {
      "type": "string",
      "description": "CAIP-2 for Solana (e.g. solana:mainnet)"
    },
    "blockNumber": {
      "minimum": 0,
      "type": "integer"
    }
  },
  "title": "token-holding"
}
