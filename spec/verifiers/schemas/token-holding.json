{
  "$id": "https://neus.network/schemas/token-holding.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "token-holding",
  "description": "Token holding verification (EVM or Solana)",
  "type": "object",
  "required": [
    "contractAddress",
    "minBalance"
  ],
  "oneOf": [
    {
      "required": [
        "chainId"
      ]
    },
    {
      "required": [
        "chain"
      ]
    }
  ],
  "properties": {
    "ownerAddress": {
      "type": "string",
      "format": "universal-address"
    },
    "contractAddress": {
      "type": "string",
      "format": "universal-address"
    },
    "minBalance": {
      "type": "string",
      "minLength": 1
    },
    "chainId": {
      "type": "integer",
      "minimum": 1
    },
    "chain": {
      "type": "string",
      "description": "CAIP-2 for Solana (e.g. solana:mainnet)"
    },
    "blockNumber": {
      "type": "integer",
      "minimum": 0
    }
  }
}
