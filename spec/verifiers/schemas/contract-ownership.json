{
  "$id": "https://neus.network/schemas/contract-ownership.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "contract-ownership",
  "description": "Verifies smart contract ownership (EVM chains)",
  "type": "object",
  "required": [
    "contractAddress",
    "chainId"
  ],
  "properties": {
    "contractAddress": {
      "type": "string",
      "format": "evm-address"
    },
    "chainId": {
      "type": "integer",
      "minimum": 1
    },
    "walletAddress": {
      "type": "string",
      "format": "evm-address"
    },
    "method": {
      "type": "string",
      "enum": [
        "owner",
        "admin",
        "accessControl"
      ]
    }
  }
}
